@model LibraryManagementSystem.ViewModels.BookCreateViewModels

@{
    ViewData["Title"] = "Add New Book";
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h4><i class="fas fa-plus-circle"></i> Add New Book</h4>
        </div>
        <div class="card-body">
            <form asp-action="Create" method="post" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="row">
                    <div class="col-md-8">
                        <div class="mb-3">
                            <label asp-for="Title" class="form-label fw-bold"></label>
                            <input asp-for="Title" class="form-control" />
                            <span asp-validation-for="Title" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Isbn" class="form-label fw-bold"></label>
                                    <input asp-for="Isbn" class="form-control" />
                                    <span asp-validation-for="Isbn" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="GenreId" class="form-label fw-bold"></label>
                                    <select asp-for="GenreId" class="form-select" asp-items="Model.GenreList">
                                    </select>
                                    <span asp-validation-for="GenreId" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Publication" class="form-label fw-bold"></label>
                                    <input asp-for="Publication" class="form-control" />
                                    <span asp-validation-for="Publication" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="PublishedYear" class="form-label fw-bold"></label>
                                    <input asp-for="PublishedYear" class="form-control" />
                                    <span asp-validation-for="PublishedYear" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Pages" class="form-label fw-bold"></label>
                                    <input asp-for="Pages" class="form-control" />
                                    <span asp-validation-for="Pages" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ShortDesc" class="form-label fw-bold"></label>
                            <textarea asp-for="ShortDesc" class="form-control" rows="4"></textarea>
                            <span asp-validation-for="ShortDesc" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label asp-for="Length" class="form-label">Length (in)</label>
                                    <input asp-for="Length" class="form-control" />
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label asp-for="Width" class="form-label">Width (in)</label>
                                    <input asp-for="Width" class="form-control" />
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label asp-for="Height" class="form-label">Height (in)</label>
                                    <input asp-for="Height" class="form-control" />
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Select Authors</label>
                            <div class="border rounded p-3" style="max-height: 200px; overflow-y: auto;">
                                @for (int i = 0; i < Model.AuthorList.Count; i++)
                                {
                                    <div class="form-check">
                                        <input type="checkbox"
                                               name="AuthorIds"
                                               value="@Model.AuthorList[i].Value"
                                               class="form-check-input"
                                               id="author_@Model.AuthorList[i].Value" />
                                        <label class="form-check-label" for="author_@Model.AuthorList[i].Value">
                                            @Model.AuthorList[i].Text
                                        </label>
                                    </div>
                                }
                            </div>
                            <span asp-validation-for="AuthorIds" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="mb-3">
                            <label asp-for="ImageFile" class="form-label fw-bold">Book Cover</label>
                            <input asp-for="ImageFile" type="file" class="form-control" accept="image/*"
                                   onchange="previewImage(this)" />
                            <small class="text-muted">Supported: JPG, PNG, GIF (Max 5MB)</small>
                            <small class="text-muted d-block">Image will be saved to: /images/books/</small>
                            
                            <div class="text-center mt-3">
                                <img id="imagePreview" class="img-fluid rounded"
                                     style="max-height: 200px; display: none; border: 1px solid #ddd; padding: 5px;" />
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mt-3">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save"></i> Create Book
                    </button>
                    <a href="@Url.Action("Index")" class="btn btn-secondary">
                        <i class="fas fa-times"></i> Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function previewImage(input) {
            var preview = document.getElementById('imagePreview');
            
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                
                reader.onload = function(e) {
                    preview.src = e.target.result;
                    preview.style.display = 'block';
                }
                
                reader.readAsDataURL(input.files[0]);
            } else {
                preview.style.display = 'none';
            }
        }
    </script>
    
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}